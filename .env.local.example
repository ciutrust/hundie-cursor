# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Server-only — never expose to browser or commit
# Required for CSV imports (npm run import:qb-gbsl, npm run import:cards)
# Required for npm run verify:db (anon cannot read ledger after RLS lockdown)
# SUPABASE_SERVICE_ROLE_KEY=

# AI pre-classifier (optional — Ask AI / AI review panel)
# ANTHROPIC_API_KEY=
# AI_MODEL=claude-sonnet-4-6

# Plaid bank sync (Connections → Sync now)
# Get sandbox keys at dashboard.plaid.com → Developers → Keys
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# 32-byte base64 key that encrypts Plaid access tokens at rest (server-only).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PLAID_TOKEN_ENC_KEY=

# Weekly "N left to categorize" digest email (optional — inert until all four are set).
# Vercel Cron calls /api/cron/weekly-digest Mon 09:00 UTC with Authorization: Bearer $CRON_SECRET.
# CRON_SECRET: generate any long random string. Set the SAME value in Vercel project env.
CRON_SECRET=
# Resend API key + a VERIFIED sender (https://resend.com → API Keys / Domains).
RESEND_API_KEY=
EMAIL_FROM=Hundie <digest@yourdomain.com>
# Where the digest goes, and the base URL used for the /review deep link in the email.
OPERATOR_EMAIL=
NEXT_PUBLIC_SITE_URL=https://your-hundie-deployment.vercel.app

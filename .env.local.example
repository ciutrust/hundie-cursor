# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here

# Server-only — never expose to browser or commit
# Required for CSV imports (npm run import:qb-gbsl, npm run import:cards)
# Required for npm run verify:db (anon cannot read ledger after RLS lockdown)
# SUPABASE_SERVICE_ROLE_KEY=

# AI pre-classifier (optional — Ask AI / AI review panel)
# ANTHROPIC_API_KEY=
# AI_MODEL=claude-sonnet-4-6

# Plaid bank sync (Connections → Sync now)
# Get sandbox keys at dashboard.plaid.com → Developers → Keys
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# 32-byte base64 key that encrypts Plaid access tokens at rest (server-only).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
PLAID_TOKEN_ENC_KEY=
